# Firebase Web SDK — required
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Admin panel password — required
# Note: any VITE_* env var is inlined into the JS bundle at build time,
# so anyone who opens devtools on the deployed site can read this value.
# Treat it as a friction layer, not as real auth.
VITE_ADMIN_PASSWORD=
