# Copy this file to `.env` for local development.
# In production (Vercel, Cloud Run, Render, etc.) set these via the platform's
# environment-variable UI.

# ------------------------------------------------------------------------------
# Admin panel password (build-time)
# ------------------------------------------------------------------------------
# Controls who can open /admin. Anyone with this password can edit rooms,
# events, alerts, etc. Defaults to "asdf" if unset — change before going live.
VITE_ADMIN_PASSWORD="asdf"

# ------------------------------------------------------------------------------
# Firebase client config (build-time, public-safe)
# ------------------------------------------------------------------------------
# These are safe to expose in client JS. Security is enforced by Firestore
# rules. Defaults baked into src/lib/firebase.ts point at the
# eqc-dashboard-by-25g project — override these to point at a different
# Firebase project.
VITE_FIREBASE_API_KEY=""
VITE_FIREBASE_AUTH_DOMAIN=""
VITE_FIREBASE_PROJECT_ID=""
VITE_FIREBASE_STORAGE_BUCKET=""
VITE_FIREBASE_MESSAGING_SENDER_ID=""
VITE_FIREBASE_APP_ID=""

# ------------------------------------------------------------------------------
# Demo / static-preview mode (build-time)
# ------------------------------------------------------------------------------
# Set to "true" for static preview deploys (e.g. GitHub Pages). When true:
# - Firebase listeners are disabled
# - Sign-on and admin writes are no-ops
# - Lobby renders against in-file demo data
VITE_DEMO_MODE=""

