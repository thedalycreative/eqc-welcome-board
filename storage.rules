rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Public read for lobby display assets (trainer photos, carousel
    // images). Writes are blocked at the rules layer — uploads must run
    // through an authenticated path before this can be re-opened.
    match /{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }
  }
}
